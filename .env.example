# Backend
API_SECRET_KEY=change-me-in-prod
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+psycopg://cyberscan:cyberscan@db:5432/cyberscan
REDIS_URL=redis://queue:6379/0
CELERY_BROKER_URL=redis://queue:6379/0
CELERY_RESULT_BACKEND=redis://queue:6379/1

# MinIO (S3-compatible artifact storage)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=cyberscan
S3_SECRET_KEY=cyberscan-secret
S3_BUCKET_ARTIFACTS=cyberscan-artifacts
S3_BUCKET_FEEDS=cyberscan-feeds

# Auth (v0.1: simple JWT; later replaced by Keycloak OIDC)
JWT_ALGORITHM=HS256
JWT_EXPIRES_MIN=60
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin

# Feeds
NVD_API_KEY=
FEEDS_REFRESH_HOURS=6
FEEDS_USE_FIXTURES=true   # use bundled fixture snapshots instead of live feeds (set false in prod)

# Scanner tuning
NAABU_RATE=1000
NAABU_CONCURRENCY=50
NUCLEI_SHARDS=4
SCAN_TIMEOUT_MIN=20

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
